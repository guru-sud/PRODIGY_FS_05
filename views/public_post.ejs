<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post - SocialApp</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #1a1a2e; color: #fff; font-family: Arial, sans-serif; }
        nav { background: #16213e; padding: 16px 24px; display: flex; justify-content: space-between; align-items: center; }
        nav h1 { color: #e94560; }
        nav a { color: #fff; text-decoration: none; margin-left: 16px; background: #e94560; padding: 8px 16px; border-radius: 8px; }
        .container { max-width: 600px; margin: 40px auto; padding: 0 16px; }
        .post { background: #16213e; padding: 24px; border-radius: 12px; }
        .post-user { font-weight: bold; color: #e94560; font-size: 18px; margin-bottom: 8px; }
        .post-time { color: #888; font-size: 12px; margin-bottom: 16px; }
        .post-content { font-size: 16px; line-height: 1.8; margin-bottom: 16px; }
        .post-image { width: 100%; border-radius: 8px; margin-bottom: 16px; }
        .post-tags { margin-bottom: 16px; }
        .tag { background: #0f3460; padding: 4px 10px; border-radius: 20px; font-size: 12px; margin-right: 6px; color: #e94560; }
        .post-stats { display: flex; gap: 16px; color: #888; margin-bottom: 16px; }
        .post-stats span { color: #e94560; font-weight: bold; }
        .comments { border-top: 1px solid #0f3460; padding-top: 16px; }
        .comments h3 { color: #e94560; margin-bottom: 12px; }
        .comment { padding: 10px 0; border-bottom: 1px solid #0f3460; }
        .comment-user { font-weight: bold; color: #e94560; font-size: 13px; }
        .comment-text { color: #ccc; font-size: 14px; }
        .join-banner { background: #e94560; padding: 20px; border-radius: 12px; margin-top: 24px; text-align: center; }
        .join-banner h3 { margin-bottom: 8px; }
        .join-banner p { color: #ffcccc; margin-bottom: 16px; font-size: 14px; }
        .join-banner a { background: #fff; color: #e94560; padding: 10px 24px; border-radius: 8px; text-decoration: none; font-weight: bold; margin: 0 8px; }
        .share-box { background: #0f3460; padding: 12px; border-radius: 8px; margin-top: 16px; }
        .share-box p { color: #888; font-size: 12px; margin-bottom: 8px; }
        .share-url { width: 100%; padding: 8px; background: #16213e; border: none; border-radius: 6px; color: #fff; font-size: 12px; }
        .copy-btn { margin-top: 8px; padding: 8px 16px; background: #e94560; border: none; border-radius: 6px; color: #fff; cursor: pointer; font-size: 12px; }
    </style>
</head>
<body>
    <nav>
        <h1>🌐 SocialApp</h1>
        <div>
            <a href="/register">Join Now!</a>
            <a href="/login" style="background:#0f3460;">Login</a>
        </div>
    </nav>

    <div class="container">
        <div class="post">
            <div class="post-user">👤 <%= post.user.username %></div>
            <div class="post-time"><%= new Date(post.createdAt).toLocaleString() %></div>
            <div class="post-content"><%= post.content %></div>

            <% if (post.image) { %>
                <img src="<%= post.image %>" class="post-image" alt="Post image" />
            <% } %>

            <% if (post.tags.length > 0) { %>
            <div class="post-tags">
                <% post.tags.forEach(tag => { %>
                    <span class="tag">#<%= tag %></span>
                <% }) %>
            </div>
            <% } %>

            <div class="post-stats">
                ❤️ <span><%= post.likes.length %></span> likes &nbsp;
                💬 <span><%= post.comments.length %></span> comments
            </div>

            <!-- Share Box -->
            <div class="share-box">
                <p>🔗 Share this post:</p>
                <input type="text" class="share-url" id="shareUrl" value="<%= `http://10.154.215.36:3000/post/${post._id}/public` %>" readonly />
                <button class="copy-btn" onclick="copyLink()">📋 Copy Link</button>
            </div>

            <!-- Comments -->
            <% if (post.comments.length > 0) { %>
            <div class="comments">
                <h3>💬 Comments</h3>
                <% post.comments.forEach(comment => { %>
                <div class="comment">
                    <span class="comment-user">👤 <%= comment.user ? comment.user.username : 'User' %>: </span>
                    <span class="comment-text"><%= comment.text %></span>
                </div>
                <% }) %>
            </div>
            <% } %>
        </div>

        <!-- Join Banner -->
        <div class="join-banner">
            <h3>🌐 Join SocialApp!</h3>
            <p>Create an account to like, comment, and share posts with the community!</p>
            <a href="/register">Register Free</a>
            <a href="/login">Login</a>
        </div>
    </div>

    <script>
        function copyLink() {
            const url = document.getElementById('shareUrl');
            url.select();
            document.execCommand('copy');
            alert('Link copied!');
        }
    </script>
</body>
</html>